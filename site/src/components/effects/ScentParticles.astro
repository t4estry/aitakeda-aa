---
/**
 * ScentParticles — 香りの視覚化エフェクト
 * カーソル移動／クリック／タップ／スワイプに反応して微細な点群が広がる。
 * 「見えない香りをまとっている」印象を作る。
 *
 * 完全に無効化したい場合：BaseLayout.astro でこのコンポーネントの import を外すだけ。
 * パフォーマンスへの配慮：
 *   - requestAnimationFrame、粒子の上限 200、mousemove スロットリング（40ms）
 *   - pointer-events: none で一切クリック遮断しない
 *   - prefers-reduced-motion で完全停止
 *
 * 調整ポイント（下記 CONFIG）：
 *   - COLOR: 粒の色（rgba 文字列）— 現状は ink 低透明
 *   - AMBIENT_RATE: カーソル停止時の自然生成量（0 で無効）
 *   - EMIT_ON_MOVE / CLICK / TOUCH の各粒子数と速度
 */
---

<canvas id="scent-canvas" aria-hidden="true"></canvas>

<style>
  #scent-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 30;
  }
  @media (prefers-reduced-motion: reduce) {
    #scent-canvas {
      display: none;
    }
  }
</style>

<script is:inline>
  (() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const canvas = document.getElementById('scent-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // ===== CONFIG =====
    // 分子構造風：カーソル連動で点が生成され、近傍同士を線で結ぶネットワーク表現
    const CONFIG = {
      MAX_PARTICLES: 130,
      COLOR: 'rgba(17, 17, 17, ',       // ink / 最後に alpha を付与
      COLOR_DARK_BG: 'rgba(246, 243, 238, ', // paper（暗い背景用）
      AMBIENT_RATE: 0, // 0=カーソル停止中は新規粒を出さない（実際の動きのみトリガー）
      EMIT_ON_MOVE: { count: 1, spread: 0.5, size: [1.0, 2.4], life: [1800, 3200] },
      EMIT_ON_CLICK: { count: 14, spread: 2.4, size: [1.2, 3.0], life: [1400, 2400] },
      EMIT_ON_TOUCH: { count: 2, spread: 0.6, size: [1.0, 2.4], life: [1800, 3200] },
      SWAY_AMPLITUDE: 0.35,
      UPWARD_DRIFT: 0.12,
      VELOCITY_DAMPING: 0.97,
      MOVE_THROTTLE_MS: 35,
      // 分子ネットワーク描画
      LINE_DIST: 120,           // この距離内の粒同士を線で結ぶ
      LINE_WIDTH: 0.6,
      DOT_ALPHA_PEAK: 0.55,     // 点のピーク透明度
      LINE_ALPHA_PEAK: 0.38,    // 線のピーク透明度（距離で減衰）
    };

    const particles = [];
    let lastFrame = performance.now();
    let lastEmit = 0;
    let mouse = { x: -9999, y: -9999, moved: false };

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      canvas.style.width = window.innerWidth + 'px';
      canvas.style.height = window.innerHeight + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    function isOverDarkBg(x, y) {
      // 画面上のその位置の背景が暗いかを、body 配下の要素から粗く判定
      const el = document.elementFromPoint(x, y);
      if (!el) return false;
      // 先祖方向に bg-ink / Hero 画像等を探索
      let cursor = el;
      for (let i = 0; i < 6 && cursor; i++) {
        const cls = cursor.classList;
        if (cls?.contains('bg-ink')) return true;
        if (cursor.tagName === 'FOOTER') return true;
        // Hero 背景画像がある節には data-component="Hero" が付与され overlay あり
        if (cursor.dataset?.component === 'Hero') return true;
        cursor = cursor.parentElement;
      }
      return false;
    }

    function emit(x, y, opts) {
      if (particles.length > CONFIG.MAX_PARTICLES) return;
      const dark = isOverDarkBg(x, y);
      for (let i = 0; i < opts.count; i++) {
        if (particles.length >= CONFIG.MAX_PARTICLES) break;
        const angle = Math.random() * Math.PI * 2;
        const speed = rand(0.15, opts.spread);
        particles.push({
          x, y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          r: rand(opts.size[0], opts.size[1]),
          life: 0,
          maxLife: rand(opts.life[0], opts.life[1]),
          sway: rand(0.1, CONFIG.SWAY_AMPLITUDE),
          swayOffset: Math.random() * Math.PI * 2,
          dark,
        });
      }
    }

    window.addEventListener(
      'mousemove',
      (e) => {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
        mouse.moved = true;
        const now = performance.now();
        if (now - lastEmit > CONFIG.MOVE_THROTTLE_MS) {
          emit(e.clientX, e.clientY, CONFIG.EMIT_ON_MOVE);
          lastEmit = now;
        }
      },
      { passive: true }
    );

    window.addEventListener(
      'click',
      (e) => emit(e.clientX, e.clientY, CONFIG.EMIT_ON_CLICK),
      { passive: true }
    );

    window.addEventListener(
      'touchstart',
      (e) => {
        const t = e.touches[0];
        if (t) emit(t.clientX, t.clientY, CONFIG.EMIT_ON_CLICK);
      },
      { passive: true }
    );

    window.addEventListener(
      'touchmove',
      (e) => {
        const t = e.touches[0];
        if (!t) return;
        const now = performance.now();
        if (now - lastEmit > CONFIG.MOVE_THROTTLE_MS) {
          emit(t.clientX, t.clientY, CONFIG.EMIT_ON_TOUCH);
          lastEmit = now;
        }
      },
      { passive: true }
    );

    function loop() {
      const now = performance.now();
      const dt = Math.min(now - lastFrame, 50);
      lastFrame = now;

      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // Ambient emission near cursor（小さくじんわり）
      if (
        mouse.moved &&
        Math.random() < CONFIG.AMBIENT_RATE &&
        particles.length < CONFIG.MAX_PARTICLES
      ) {
        emit(
          mouse.x + rand(-20, 20),
          mouse.y + rand(-20, 20),
          CONFIG.EMIT_ON_MOVE
        );
      }

      // Phase 1: 粒の物理更新（寿命切れを削除、alpha/radius をキャッシュ）
      const alive = [];
      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.life += dt;
        if (p.life > p.maxLife) {
          particles.splice(i, 1);
          continue;
        }
        const sway = Math.sin(p.life / 400 + p.swayOffset) * p.sway;
        p.x += p.vx + sway;
        p.y += p.vy - CONFIG.UPWARD_DRIFT;
        p.vx *= CONFIG.VELOCITY_DAMPING;
        p.vy *= CONFIG.VELOCITY_DAMPING;

        const t = p.life / p.maxLife;
        const life01 = Math.sin((1 - t) * Math.PI); // 0→1→0 の山型
        p._dotAlpha = life01 * CONFIG.DOT_ALPHA_PEAK;
        p._dotR = Math.max(1.0, p.r * (0.8 + life01 * 0.4));
        p._life01 = life01;
        alive.push(p);
      }

      // Phase 2: 近傍間を線で結ぶ（分子構造）
      ctx.lineWidth = CONFIG.LINE_WIDTH;
      const maxDistSq = CONFIG.LINE_DIST * CONFIG.LINE_DIST;
      for (let i = 0; i < alive.length; i++) {
        const a = alive[i];
        for (let j = i + 1; j < alive.length; j++) {
          const b = alive[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const dsq = dx * dx + dy * dy;
          if (dsq > maxDistSq) continue;
          const dist = Math.sqrt(dsq);
          const falloff = 1 - dist / CONFIG.LINE_DIST;
          const la =
            falloff *
            Math.min(a._life01, b._life01) *
            CONFIG.LINE_ALPHA_PEAK;
          if (la <= 0.005) continue;
          const base = a.dark ? CONFIG.COLOR_DARK_BG : CONFIG.COLOR;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = base + la.toFixed(3) + ')';
          ctx.stroke();
        }
      }

      // Phase 3: 点の描画（ソリッドな分子）
      for (let i = 0; i < alive.length; i++) {
        const p = alive[i];
        const base = p.dark ? CONFIG.COLOR_DARK_BG : CONFIG.COLOR;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p._dotR, 0, Math.PI * 2);
        ctx.fillStyle = base + p._dotAlpha.toFixed(3) + ')';
        ctx.fill();
      }

      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);
  })();
</script>
