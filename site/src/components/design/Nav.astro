---
interface NavLink {
  label: string;
  href: string;
}
interface Props {
  brandName: string;
  links: NavLink[];
  overlay?: boolean; // trueでヒーロー画像上に透明ナビとして配置
}
const { brandName, links, overlay = false } = Astro.props;

const wrapClass = overlay
  ? 'absolute top-0 left-0 right-0 z-50'
  : 'sticky top-0 z-50 bg-paper/90 backdrop-blur-md border-b border-fog';

const textColorClass = overlay ? 'text-paper' : 'text-ink';
const linkColorClass = overlay
  ? 'text-paper/80 hover:text-paper'
  : 'text-ink/70 hover:text-moss';
const buttonColorClass = overlay
  ? 'border-paper/50 text-paper'
  : 'border-ink/40 text-ink';
---

<header class={wrapClass}>
  <nav class="mx-auto max-w-[1440px] flex items-center justify-between px-4 md:px-24 py-6">
    <a
      href="/"
      class={`font-[var(--font-caption-en)] text-[13px] tracking-[0.35em] uppercase font-medium ${textColorClass}`}
    >
      {brandName}
    </a>
    <ul class="hidden md:flex items-center gap-10">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class={`font-[var(--font-caption-en)] text-[11px] tracking-[0.25em] uppercase transition-colors ${linkColorClass}`}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
    <button
      type="button"
      aria-label="メニューを開く"
      class={`md:hidden text-[11px] tracking-[0.25em] uppercase border rounded-xs px-4 py-2 ${buttonColorClass}`}
    >
      Menu
    </button>
  </nav>
</header>
