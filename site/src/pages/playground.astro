---

<BaseLayout title="Playground" description="Phase 2 design component catalog">
  <Nav brandName={SITE.brandNameEn} links={navLinks} />

  <main>
    <Hero
      tagline={SITE.tagline}
      headline={'森の呼吸を、\n調香する。'}
      sub={'愛媛・内子の山から、\n未利用の枝葉を蒸留し、香りに変える。\n調香師 武田愛の、森から始まる設計。'}
    />

    <section id="service" class="mx-auto max-w-[1440px] px-4 md:px-24 py-48">
      <SectionHeader
        label="SERVICE"
        heading="香りで、空間とブランドを設計する。"
      />
      <div class="grid md:grid-cols-2 gap-16">
        {services.map((s) => <ServiceCard {...s} />)}
      </div>
    </section>

    <section id="works" class="mx-auto max-w-[1440px] px-4 md:px-24 py-48">
      <SectionHeader label="WORKS" heading="これまでの調香。" />
      <div class="grid md:grid-cols-3 gap-10">
        {works.map((w) => <WorkCard {...w} />)}
      </div>
    </section>

    <section
      id="products"
      class="mx-auto max-w-[1440px] px-4 md:px-24 py-48"
    >
      <SectionHeader
        label="PRODUCTS"
        heading="森の香りを、手の届くかたちに。"
      />
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
        {products.map((p) => <ProductCard {...p} />)}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
