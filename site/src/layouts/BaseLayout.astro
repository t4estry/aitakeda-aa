---
import '../styles/global.css';
import { SITE } from '../config/site';
// 香りの視覚化エフェクト — 不要なら次行をコメントアウトするだけで完全に無効化
import ScentParticles from '../components/effects/ScentParticles.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE.brandName,
  description = SITE.tagline,
} = Astro.props;

const fullTitle = title === SITE.brandName ? title : `${title} ｜ ${SITE.brandName}`;

// プレビュー段階は検索エンジンに拾われないよう noindex。本番公開時に env で切り替え可能。
// 環境変数 PUBLIC_SITE_PUBLIC=true でインデックス許可に切り替わる。
const allowIndexing = import.meta.env.PUBLIC_SITE_PUBLIC === 'true';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    {/* プレビュー段階：検索エンジン除外。PUBLIC_SITE_PUBLIC=true で解除 */}
    {!allowIndexing && (
      <meta name="robots" content="noindex, nofollow" />
    )}

    <!-- Google Fonts — DESIGN_SPEC §5.2 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;700&family=Noto+Sans+JP:wght@400;500;700&family=Shippori+Mincho+B1:wght@500;600;700&family=Cormorant+Garamond:ital,wght@0,400;1,400;1,500&family=Inter:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <slot />
    <ScentParticles />
  </body>
</html>
