---
/**
 * News 一覧ページ — 投稿型、シンプルで堅牢
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/design/Nav.astro';
import Footer from '../../components/design/Footer.astro';
import { SITE } from '../../config/site';

const navLinks = [
  { label: 'About', href: '/#about' },
  { label: 'Service', href: '/#service' },
  { label: 'Works', href: '/works' },
  { label: 'Products', href: '/#products' },
  { label: 'Contact', href: '/#contact' },
];

const newsItems = (await getCollection('news')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---

<BaseLayout title="News" description="AI TAKEDA からのお知らせ">
  <Nav brandName={SITE.brandNameEn} links={navLinks} />

  <main>
    {/* ページヒーロー */}
    <section class="bg-paper">
      <div
        class="mx-auto max-w-[1440px] px-4 md:px-24 pt-40 md:pt-48 pb-20 md:pb-28"
      >
        <p class="font-[var(--font-caption-en)] text-[11px] tracking-[0.35em] uppercase text-moss">
          NEWS
        </p>
        <h1
          class="mt-6 font-[var(--font-display-jp)] text-4xl md:text-7xl leading-[1.3] tracking-tight"
        >
          お知らせ。
        </h1>
        <p class="mt-10 max-w-2xl text-[15px] leading-[2.1] text-ink/80 border-t border-fog pt-10">
          活動、メディア掲載、イベント出展などのお知らせです。
        </p>
      </div>
    </section>

    {/* 記事リスト */}
    <section class="bg-paper-alt">
      <div class="mx-auto max-w-[1440px] px-4 md:px-24 py-20 md:py-28">
        <ul class="border-t border-ink/15">
          {
            newsItems.map((n) => (
              <li class="border-b border-ink/15">
                <a
                  href={`/news/${n.id}`}
                  class="grid md:grid-cols-[160px,1fr,auto] gap-6 items-baseline py-7 md:py-8 hover:text-moss transition-colors group"
                >
                  <time class="font-[var(--font-caption-en)] text-[11px] tracking-[0.25em] text-ink/60">
                    {formatDate(n.data.date)}
                  </time>
                  <span class="text-[15px] md:text-base leading-[1.7]">
                    {n.data.title}
                  </span>
                  <span class="hidden md:inline font-[var(--font-caption-en)] text-xs text-ink/40 group-hover:text-moss group-hover:translate-x-1 transition-all">
                    →
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
