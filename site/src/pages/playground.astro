 * 7コンポーネント（Nav / Hero / SectionHeader / ServiceCard / WorkCard / ProductCard / Footer）を
 * 一覧表示して目視確認する。実データ置換は Phase 3-4 で対応。
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/design/Nav.astro';
import Footer from '../components/design/Footer.astro';
import Hero from '../components/design/Hero.astro';
import SectionHeader from '../components/design/SectionHeader.astro';
import ServiceCard from '../components/design/ServiceCard.astro';
import WorkCard from '../components/design/WorkCard.astro';
import ProductCard from '../components/design/ProductCard.astro';
import { SITE } from '../config/site';

