---
interface Props {
  cover: string;
  category: string; // 空間香 / 商品香 / 講演 / 執筆
  title: string;
  client?: string;
  year?: string;
  summary: string;
  href?: string;
  /**
   * カバー画像のアスペクト比クラス。
   * デフォルトは portrait `aspect-[4/5]`（/works 一覧用）。
   * Top 抜粋カルーセルでは `aspect-[5/4]` 等の landscape を指定して縦比率を抑える。
   */
  coverAspect?: string;
}
const {
  cover,
  category,
  title,
  client,
  year,
  summary,
  href = '#',
  coverAspect = 'aspect-[4/5]',
} = Astro.props;
---

<a href={href} class="group block">
  <div class={`${coverAspect} overflow-hidden bg-fog`}>
    <img
      src={cover}
      alt={title}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-[1200ms] ease-[var(--ease-out-soft)] group-hover:scale-[1.04] grayscale"
    />
  </div>
  <div class="mt-6 flex items-baseline justify-between font-[var(--font-caption-en)] text-xs tracking-[0.3em] uppercase">
    <span class="text-moss">{category}</span>
    {year && <span class="text-ink/50">{year}</span>}
  </div>
  <h3
    class="mt-3 font-[var(--font-display-jp)] text-2xl leading-[1.4] group-hover:text-moss transition-colors"
  >
    {title}
  </h3>
  {client && (
    <p class="mt-2 font-[var(--font-caption-en)] text-xs tracking-wider text-ink/60">
      {client}
    </p>
  )}
  <p class="mt-3 text-sm leading-[1.9] text-ink/80">
    {summary}
  </p>
</a>
