---
/**
 * Carousel — CSS scroll-snap ベースの水平カルーセル
 * - モバイル：スワイプで自然にスナップ
 * - PC：サムネイル上にオーバーレイした前後ボタン＋進行カウンタ
 * - アイテム幅は親コンポーネントの `class` で制御する前提
 *
 * 使い方：
 *   <Carousel buttonTop="40%">
 *     <div class="carousel-item w-[85%] md:w-[40%]"><WorkCard ... /></div>
 *   </Carousel>
 */
interface Props {
  label?: string; // ARIA ラベル
  gap?: string; // Tailwind の gap クラス
  showControls?: boolean;
  showCounter?: boolean;
  buttonTop?: string; // ボタンをサムネイルに重ねる位置（track 内の縦％）
}

const {
  label = 'カルーセル',
  gap = 'gap-5 md:gap-6',
  showControls = true,
  showCounter = true,
  buttonTop = '40%',
} = Astro.props;
---

<section
  class="carousel-root relative"
  role="region"
  aria-roledescription="carousel"
  aria-label={label}
  data-component="Carousel"
>
  <div class="carousel-viewport relative">
    <div
      class={`carousel-track flex overflow-x-auto snap-x snap-mandatory ${gap} -mx-4 px-4 md:-mx-24 md:px-24`}
      tabindex="0"
    >
      <slot />
    </div>

    {
      showControls && (
        <>
          <button
            type="button"
            class="carousel-prev hidden md:flex absolute z-20 left-6 md:left-10 w-12 h-12 lg:w-14 lg:h-14 border border-paper/70 bg-ink/35 backdrop-blur-sm rounded-full items-center justify-center text-paper hover:bg-ink/70 transition-all disabled:opacity-0 disabled:pointer-events-none"
            style={`top: ${buttonTop}; transform: translateY(-50%);`}
            aria-label="前へ"
            data-prev
          >
            <span aria-hidden="true" class="text-lg">←</span>
          </button>
          <button
            type="button"
            class="carousel-next hidden md:flex absolute z-20 right-6 md:right-10 w-12 h-12 lg:w-14 lg:h-14 border border-paper/70 bg-ink/35 backdrop-blur-sm rounded-full items-center justify-center text-paper hover:bg-ink/70 transition-all disabled:opacity-0 disabled:pointer-events-none"
            style={`top: ${buttonTop}; transform: translateY(-50%);`}
            aria-label="次へ"
            data-next
          >
            <span aria-hidden="true" class="text-lg">→</span>
          </button>
        </>
      )
    }
  </div>

  {
    showCounter && (
      <div class="mt-8 md:mt-10 flex items-center justify-center">
        <div class="font-[var(--font-caption-en)] text-[11px] tracking-[0.3em] text-ink/60">
          <span data-counter>01</span>
          <span class="mx-2 text-ink/30">／</span>
          <span data-total>--</span>
        </div>
      </div>
    )
  }
</section>

<style>
  .carousel-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }
  .carousel-track::-webkit-scrollbar {
    display: none;
  }
  .carousel-track > :global(*) {
    flex: 0 0 auto;
    scroll-snap-align: start;
  }
  .carousel-track:focus-visible {
    outline: 1px solid var(--color-ink);
    outline-offset: 4px;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-component="Carousel"]').forEach((root) => {
    const track = root.querySelector<HTMLElement>('.carousel-track');
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-prev]');
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-next]');
    const counterEl = root.querySelector<HTMLElement>('[data-counter]');
    const totalEl = root.querySelector<HTMLElement>('[data-total]');

    if (!track) return;

    const items = Array.from(track.children) as HTMLElement[];
    if (items.length === 0) return;

    if (totalEl) totalEl.textContent = String(items.length).padStart(2, '0');

    function currentIndex(): number {
      let nearest = 0;
      let minDist = Infinity;
      items.forEach((el, i) => {
        const dist = Math.abs(el.offsetLeft - track.scrollLeft);
        if (dist < minDist) {
          minDist = dist;
          nearest = i;
        }
      });
      return nearest;
    }

    function scrollToIndex(i: number) {
      const clamped = Math.max(0, Math.min(items.length - 1, i));
      const target = items[clamped];
      if (!target) return;
      track.scrollTo({ left: target.offsetLeft, behavior: 'smooth' });
    }

    function updateState() {
      const idx = currentIndex();
      if (counterEl) counterEl.textContent = String(idx + 1).padStart(2, '0');
      if (prevBtn) prevBtn.disabled = idx === 0;
      if (nextBtn) {
        const lastItem = items[items.length - 1];
        const atEnd =
          track.scrollLeft + track.clientWidth >= lastItem.offsetLeft + lastItem.offsetWidth - 4;
        nextBtn.disabled = atEnd;
      }
    }

    prevBtn?.addEventListener('click', () => scrollToIndex(currentIndex() - 1));
    nextBtn?.addEventListener('click', () => scrollToIndex(currentIndex() + 1));

    let rafId = 0;
    track.addEventListener('scroll', () => {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(updateState);
    });
    window.addEventListener('resize', updateState);

    track.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        scrollToIndex(currentIndex() + 1);
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        scrollToIndex(currentIndex() - 1);
      }
    });

    updateState();
  });
</script>
